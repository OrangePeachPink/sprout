# .clang-format - C/C++ formatting policy for the plants firmware.
# Tool: clang-format (LLVM). Tuned to the existing firmware house style:
# 4-space indent, function brace on its own line, K&R control braces,
# 80 columns, pointer binds to the name.
#
# Pinned for idempotency with clang-format v22 (mirrors-clang-format v22.1.5,
# the version wired in .pre-commit-config.yaml). Two options added vs the
# original draft to prevent oscillation (#120):
#   AlignTrailingComments:false — comment-alignment re-aligns on every pass
#   ReflowComments:false        — block-comment word-wrap re-wraps on every pass
---
Language: Cpp
BasedOnStyle: LLVM
IndentWidth: 4
TabWidth: 4
UseTab: Never
ColumnLimit: 80
BreakBeforeBraces: Linux
PointerAlignment: Right
AllowShortFunctionsOnASingleLine: None
AllowShortIfStatementsOnASingleLine: WithoutElse
AllowShortLoopsOnASingleLine: false
KeepEmptyLinesAtTheStartOfBlocks: false
SpaceAfterCStyleCast: false
AlignTrailingComments: false
ReflowComments: false
# Keep include order as written - C headers can be order-sensitive.
SortIncludes: false
