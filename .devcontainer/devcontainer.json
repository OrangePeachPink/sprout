// Sprout devcontainer — "Open in Codespaces" → a full, ready dev env in the browser,
// zero local setup (Frictionless GitHub Experience, #110). It reproduces the SAME env as
// local + CI: uv-managed Python, just, node (for markdownlint), gcc (for the native tests).
{
  "name": "Sprout",
  // buildpack-deps base → gcc/make already present for `just test-native`.
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "features": {
    // node provides npx for the markdownlint hook.
    "ghcr.io/devcontainers/features/node:1": {}
  },
  // Install the runner + env, then reproduce deps and wire the hooks (one setup script).
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "customizations": {
    "vscode": {
      // The editor offers these on open, so format-on-save / lint / TOML all "just work".
      "extensions": [
        "charliermarsh.ruff",
        "ms-python.python",
        "platformio.platformio-ide",
        "editorconfig.editorconfig",
        "davidanson.vscode-markdownlint",
        "tamasfe.even-better-toml"
      ]
    }
  },
  // uv + just install to ~/.local/bin; make sure it's on PATH for terminals.
  "remoteEnv": {
    "PATH": "${containerEnv:HOME}/.local/bin:${containerEnv:PATH}"
  }
}
