root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Python is 4-space (PEP 8 / ruff) — keep the editor in step with the formatter.
[*.py]
indent_size = 4

# Firmware C/C++ house style is 4-space.
[*.{c,h,cpp}]
indent_size = 4

[*.{bat,cmd,url}]
end_of_line = crlf

[*.md]
trim_trailing_whitespace = false
