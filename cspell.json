{
  // Project dictionary for the plants controller - hardware part names, pin
  // labels, and toolchain terms not in the base English dictionary.
  "version": "0.2",
  // Both locales at once (#524): cspell accepts a word if it matches EITHER, so US and
  // UK spelling both pass with zero custom-dictionary entries — kills the whole
  // behaviour/colour/analyse/travelling class permanently instead of allowlisting each
  // variant one PR-bounce at a time. Verified against the full docs corpus before
  // landing: zero regressions, and it let the ten pure-locale words below come out of
  // the list (they're covered by en-GB now, not by name).
  "language": "en,en-GB",
  // Skip everything .gitignore already excludes (_scratch/, logs, build outputs,
  // .env*, config/location.local.json, ...). The hook lints "**/*.md" with always_run,
  // and that glob does NOT honor .gitignore on its own — so untracked scratch .md
  // (e.g. Sage's recovery dumps under _scratch/) would otherwise fail the hook on
  // content that isn't even in the repo, and lanes skip cspell to commit. Fixing the
  // class at the root instead of allowlisting one dir at a time (#388; cf. #337).
  "useGitignore": true,
  // Design owns docs/design/** (its own brand vocabulary); spell-check the rest.
  // docs/experiments/** is bench evidence — capture-id slugs, device codes, and
  // technique shorthand by nature (a fresh slug every session, e.g. "...-recov",
  // "...-platepaper"). cspell's always-run scan would block EVERY lane's commit on
  // every bench session, so it's excluded like design rather than allowlisting each
  // slug. Trade-off: prose typos in bench logs aren't caught — acceptable for
  // factual evidence records (#332/#333 bench-procedure wave).
  "ignorePaths": [
    "docs/design/**",
    "docs/experiments/**"
  ],
  "words": [
    "LEDC",
    "microzone",
    "microzones",
    "resoak",
    "rootbound",
    "itime",
    // Contextual env-source names (#418 / ADR-0023): the Zigbee protocol and the
    // `context_source` identifiers sht45_onrig / weather_openmeteo (cspell splits
    // snake_case, so it sees "onrig" / "openmeteo" as tokens).
    "Zigbee",
    "onrig",
    "openmeteo",
    // Local-time-first surfaces (#328): the timefmt module name and the Python
    // stdlib `zoneinfo` (IANA DST-correct abbreviations) named in the convention doc.
    "timefmt",
    "zoneinfo",
    // Intentional prose coinages from the developer front door (#219): "dogfood"
    // (the design-dogfooding concept) and "contributable" (DX's voice). Allowlisted
    // so cspell --all-files passes; reword the prose and drop these if voice changes.
    "contributable",
    "dogfood",
    "repotting",
    "hotspot",
    "flasher",
    "untethered",
