# Default: normalize text to LF in the repo
* text=auto eol=lf

# Windows-only files keep CRLF
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.url  text eol=crlf

# Binary assets (never normalize)
*.png  binary
*.ico  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.pdf  binary
*.pptx binary
*.bin  binary
*.hex  binary
*.elf  binary

# Uppercase variants (gitattributes matching is case-sensitive)
*.JPEG binary
*.JPG  binary
*.MOV  binary

# GitHub Linguist: keep the language bar honest — this is an embedded-C + Python
# project, not a web app. Exclude design docs / generated pages / archives from stats.
docs/design/**          linguist-documentation
**/*.dc.html            linguist-generated
docs/design/_archive/** linguist-vendored
# Monocypher is vendored third-party crypto (#1282), not our code — ~148 KB, about a
# third of the repo's C. Counting it as ours overstates the C we actually wrote, which
# is the same reasoning as the three lines above.
firmware/lib/monocypher/** linguist-vendored

# Append-only registries: auto-resolve "keep both" conflicts with the built-in `union`
# merge driver (both sides' added lines kept), so two lanes appending in parallel don't
# force an Update-branch + a second required-CI run (#471). Review still catches the rare
# interleaving that needs manual ordering/dedup.
docs/adr/0000-record-architecture-decisions.md merge=union
