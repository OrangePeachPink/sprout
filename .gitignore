# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE — ignore personal .vscode files, but COMMIT the two shared ones
# (recommended extensions + format-on-save) so the editor helps every contributor.
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*~

# Agent / session state (never track)
.claude/

# Secrets / local config (KEEP OUT OF GIT)
.env
.env.*
# but DO commit the template (establishes the .env habit):
!.env.example
secrets.h
wifi_credentials.h
credentials.h

# PlatformIO
.pio/
.pioenvs/
.piolibdeps/

# Arduino build artifacts
build/
*.bin
*.elf
*.hex
*.map

# Python (logging / analysis tooling, if added later)
__pycache__/
*.pyc
.venv/
venv/

# Native (host) test build artifacts
tests/native/*.exe
tests/native/*.o

# Logs / scratch
*.log
logs/
_scratch/

# Experiment-mode raw captures (Epic 1) - isolated from logs/, never tracked
experiments/

# Generated analysis output (derived from logs/, rebuilt by tools/analytics - never tracked)
reports/

# Git LFS data-archive worktree (B8) - linked worktree on the `data` branch
.data-worktree/

# Local-only evidence video (kept out of git to avoid permanent repo bloat)
*.mov
*.MOV
.gstack/
